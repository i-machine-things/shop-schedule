GMAIL_USER=your@gmail.com
GMAIL_PASS=xxxx-xxxx-xxxx-xxxx
SHOP_NAME="Your Shop Name"
# Company name exactly as it appears in the PDF header — used to skip that line during parsing.
PDF_COMPANY_NAME="Your Company Name"
# Filename for the saved Foreman's Report PDF (default: last_report.pdf).
# Set this to something specific so the script never accidentally parses a stray PDF.
PDF_FILENAME=foremans_report.pdf
# Password for the SMB share (\\<device-ip>\schedule-drop) — set by install.sh
SMB_PASS=your-smb-password
